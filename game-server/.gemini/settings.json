{
  "general": {
    "defaultApprovalMode": "plan",
    "plan": {
      "enabled": true,
      "directory": ".gemini/plans"
    }
  },
  "mcp": {
    "allowed": ["lsp", "graph", "github"]
  },
  "mcpServers": {
    "lsp": {
      "command": "uvx",
      "args": ["mcp-language-server", "--workspace", "."],
      "cwd": ".",
      "timeout": 600000,
      "trust": true
    },
    "graph": {
      "command": "python3",
      "args": ["tools/graph_mcp_server.py"],
      "cwd": ".",
      "timeout": 600000,
      "trust": true
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "GITHUB_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "timeout": 600000,
      "trust": true
    }
  }
}
